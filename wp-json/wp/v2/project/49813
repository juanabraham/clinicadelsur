is removible<\/strong><\/p>\n<p>Tratamiento que reemplaza varios dientes perdidos mediante estructuras que pueden ser removidas por el paciente, devolvi\u00e9ndole la forma, funci\u00f3n y est\u00e9tica.<\/p>\n<p>[\/et_pb_text][et_pb_sidebar orientation=&#8221;right&#8221; area=&#8221;sidebar-2&#8243; _builder_version=&#8221;4.16&#8243; body_font=&#8221;|300|||||||&#8221; global_colors_info=&#8221;{}&#8221;][\/et_pb_sidebar][\/et_pb_column][\/et_pb_row][\/et_pb_section]<\/p>\n","protected":false},"excerpt":{"rendered":"<p>Parte de la odontolog\u00eda encargada de devolver la forma, funci\u00f3n y est\u00e9tica de los dientes del paciente&#8230;<\/p>\n","protected":false},"author":1,"featured_media":50101,"comment_status":"closed","ping_status":"closed","template":"","meta":{"_et_pb_use_builder":"on","_et_pb_old_content":"","_et_gb_content_width":"","_joinchat":[],"footnotes":""},"project_category":[23],"project_tag":[],"class_list":["post-49813","project","type-project","status-publish","has-post-thumbnail","hentry","project_category-especialidades-dentales"],"_links":{"self":[{"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/project\/49813","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/project"}],"about":[{"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/types\/project"}],"author":[{"embeddable":true,"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/comments?post=49813"}],"version-history":[{"count":12,"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/project\/49813\/revisions"}],"predecessor-version":[{"id":53212,"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/project\/49813\/revisions\/53212"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/media\/50101"}],"wp:attachment":[{"href":"https:\/\/clinicadelsur.cl\/wp-json\/wp\/v2\/media?parent=49813"}],"wp: