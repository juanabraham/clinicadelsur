		<item>
		<title>Cómo prevenir las caries dentales</title>
		<link>/2019/10/11/como-prevenir-las-caries-dentales/</link>
		
		<dc:creator><![CDATA[Clínica del sur]]></dc:creator>
		<pubDate>Fri, 11 Oct 2019 17:46:15 +0000</pubDate>
				<category><![CDATA[Salud bucal en Clínica del sur]]></category>
